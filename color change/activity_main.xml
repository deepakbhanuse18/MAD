<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    style="@style/ScreenContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <View
        android:id="@+id/colorCanvas"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#FF6B6B" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_14"
        android:orientation="horizontal"
        android:weightSum="3">

        <Button android:id="@+id/btnCoral" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Coral" />
        <Button android:id="@+id/btnMint" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="@dimen/space_8" android:layout_weight="1" android:text="Mint" />
        <Button android:id="@+id/btnSky" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="@dimen/space_8" android:layout_weight="1" android:text="Sky" />
    </LinearLayout>
</LinearLayout>
